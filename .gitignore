# See https://help.github.com/articles/ignoring-files/

# Dependencies
node_modules/
.pnpm-store/

# Testing
coverage/
*.lcov

# Next.js
.next/
out/
build/

# Env (never commit secrets — keep .env.example tracked)
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log
dev-debug.log

# Local / misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# IDE — share optional team defaults; un-ignore files you commit
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tooling caches
.eslintcache
.prettiercache
.turbo

# Convex / local deployment artifacts (if present)
.convex/

# SQLite (local tools / legacy)
*.sqlite
*.sqlite-journal
*.sqlite3

# Task / agent (local)
/.taskmaster
/.cursor
